{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["ESNext"],
    "paths": {
      "": ["./src/"],
      "@/*": ["./src/*"]
    },

    "module": "esnext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}