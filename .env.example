## Credenciais do banco PostgreSQL usado no Docker e no ambiente local.
## Troque esses valores pelos dados do seu banco.
POSTGRES_USER=seu_usuario_postgres
POSTGRES_PASSWORD=sua_senha_postgres
POSTGRES_DB=nome_do_banco

## Porta em que a API vai rodar.
PORT=3333

## String de conexão do banco no ambiente local.
## Exemplo: postgresql://usuario:senha@localhost:5432/nome_do_banco?schema=public
DATABASE_URL="sua_string_de_conexao_local"

## String de conexão do banco quando a aplicação roda via Docker Compose.
## Exemplo: postgresql://usuario:senha@postgres:5432/nome_do_banco?schema=public
DATABASE_URL_DOCKER="sua_string_de_conexao_docker"

## Chave usada para assinar e validar os tokens JWT.
JWT_SECRET="sua_chave_secreta_jwt"